# Copy to e2e/.env for local Sauce runs (never commit).
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723
APPIUM_PROVIDER=

# Local binaries (defaults point at repo build outputs)
# MOBILE_APP_ANDROID_APP=../android/app/build/outputs/apk/release/app-release.apk
# MOBILE_APP_IOS_APP=../ios/build/Build/Products/Release-iphonesimulator/AStream.app

# Sauce Labs
SAUCE_USERNAME=
SAUCE_ACCESS_KEY=
MOBILE_APP_SAUCE_APP=
SAUCE_DEVICE_NAME=Google Pixel 7 GoogleAPI Emulator
SAUCE_PLATFORM_VERSION=14.0
